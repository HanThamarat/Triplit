{
  "name": "triplit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typeorm": "ts-node -r reflect-metadata ./node_modules/typeorm/cli.js --dataSource typeorm.config.ts",
    "migration:generate": "pnpm typeorm migration:generate src/migrations/$npm_config_name",
    "migration:run": "pnpm typeorm migration:run",
    "migration:revert": "pnpm typeorm migration:revert",
    "migration:create": "pnpm typeorm migration:create src/migrations/$npm_config_name"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.10",
    "@react-icons/all-files": "^4.1.0",
    "@reduxjs/toolkit": "^2.12.0",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "google": "link:@next/third-parties/google",
    "i": "^0.3.7",
    "next": "16.2.6",
    "npm": "^11.16.0",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "reflect-metadata": "^0.2.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
